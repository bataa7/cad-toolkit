# MySQL 安全配置示例
# 路径：/etc/mysql/my.cnf (Debian/Ubuntu) 或 /etc/my.cnf (CentOS/RHEL)

[mysqld]
# 1. 仅监听内网 IP (例如数据区网关 IP)
# 避免监听 0.0.0.0 (所有接口)
bind-address = 10.10.10.10

# 2. 禁用 DNS 反向解析 (加速连接，避免 DNS 劫持)
skip-name-resolve

# 3. 强制使用 TLS 加密连接 (如果客户端在同一内网且可信，可根据实际情况配置)
# require_secure_transport = ON
# ssl-ca=/etc/mysql/ssl/ca.pem
# ssl-cert=/etc/mysql/ssl/server-cert.pem
# ssl-key=/etc/mysql/ssl/server-key.pem

# 4. 日志审计 (记录慢查询和错误日志)
log_error = /var/log/mysql/error.log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/mysql-slow.log
long_query_time = 2

# 5. 连接超时设置 (防止死连接占用资源)
wait_timeout = 600
interactive_timeout = 600

# 6. 最大连接数限制
max_connections = 500

# 7. 密码策略 (需要在安装后通过 VALIDATE PASSWORD 插件配置)
# plugin-load-add=validate_password.so
# validate_password_policy=STRONG
# validate_password_length=12

# 注意：需移除测试数据库和匿名用户
# DELETE FROM mysql.user WHERE User='';
# DROP DATABASE test;
# FLUSH PRIVILEGES;
